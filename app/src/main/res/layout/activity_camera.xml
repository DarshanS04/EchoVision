<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Camera preview - full screen -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="Camera preview"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status overlay -->
    <TextView
        android:id="@+id/camera_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Point camera at an object"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:background="#88000000"
        android:padding="12dp"
        android:importantForAccessibility="yes"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/camera_action_bar"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back_camera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go back"
            android:layout_marginHorizontal="8dp"
            android:tint="@color/white" />

        <!-- Detect objects -->
        <Button
            android:id="@+id/btn_detect"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Detect"
            android:backgroundTint="@color/accent_blue"
            android:textColor="@color/white"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="Detect objects in camera view" />

        <!-- OCR -->
        <Button
            android:id="@+id/btn_ocr"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Read Text"
            android:backgroundTint="@color/accent_green"
            android:textColor="@color/white"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="Read text in camera view" />

        <!-- Barcode -->
        <Button
            android:id="@+id/btn_barcode"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Scan QR"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/white"
            android:layout_marginHorizontal="4dp"
            android:contentDescription="Scan barcode or QR code" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
