<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Main screen for VisionAssist
  High-contrast dark design for accessibility.
  Large voice button dominates the centre.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ui.activities.MainActivity">

    <!-- App Title -->
    <TextView
        android:id="@+id/app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VisionAssist"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:importantForAccessibility="yes"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Press button or Vol Up+Down"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:importantForAccessibility="yes"
        android:contentDescription="Assistant status"
        app:layout_constraintTop_toBottomOf="@id/app_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Central Voice Button -->
    <com.visionassist.ui.components.VoiceButton
        android:id="@+id/voice_button"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/ic_mic"
        android:background="@drawable/voice_button_bg"
        android:contentDescription="Activate voice assistant"
        android:importantForAccessibility="yes"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fragment Container for AssistantFragment -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="120dp"
        app:layout_constraintTop_toBottomOf="@id/voice_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Last Response Text -->
    <TextView
        android:id="@+id/response_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="16dp"
        android:importantForAccessibility="yes"
        android:contentDescription="Assistant response"
        app:layout_constraintTop_toBottomOf="@id/fragment_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp" />

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bg_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Camera Button -->
        <ImageButton
            android:id="@+id/camera_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Open camera for object detection"
            android:layout_marginHorizontal="24dp"
            android:importantForAccessibility="yes" />

        <!-- Settings Button -->
        <ImageButton
            android:id="@+id/settings_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Open settings"
            android:layout_marginHorizontal="24dp"
            android:importantForAccessibility="yes" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
